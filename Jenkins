pipeline {
    agent any
    
    stages {
        stage('Checkout') {
            steps {
                // Pull code from GitHub
                checkout scm
                echo 'Code checked out successfully!'
            }
        }
        
        stage('Build') {
            steps {
                echo 'Building the application...'
                // Simulate a build step
                sh 'echo "Build started at $(date)" > build-info.txt'
                sh 'cat build-info.txt'
            }
        }
        
        stage('Test') {
            steps {
                echo 'Running tests...'
                // Simulate tests
                sh 'echo "All tests passed!"'
            }
        }
        
        stage('Deploy') {
            steps {
                echo 'Deploying application...'
                // In real world, this would deploy to server
                sh 'echo "Deployed successfully!"'
            }
        }
    }
    
    post {
        always {
            echo 'Pipeline completed!'
        }
        success {
            echo '✅ Build successful!'
        }
        failure {
            echo '❌ Build failed!'
        }
    }
}
